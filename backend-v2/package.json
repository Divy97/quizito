{
  "name": "quizito-backend-v2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "dev": "dotenv -e .env -- serverless offline --httpPort 4000 --stage dev",
    "deploy": "dotenv -e .env -- serverless deploy --stage dev",
    "deploy:prod": "dotenv -e .env -- serverless deploy --stage prod",
    "deploy:fn": "dotenv -e .env -- serverless deploy function --stage dev -f",
    "deploy:fn:prod": "dotenv -e .env -- serverless deploy function --stage prod -f",
    "migrate": "docker run --rm -v \"$PWD/migrations:/migrations:ro\" postgres:16-alpine sh -c 'psql \"$DATABASE_URL\" -v ON_ERROR_STOP=1 -f /migrations/0001_initial_schema.sql'",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@langchain/anthropic": "^0.3.23",
    "@langchain/core": "^0.3.61",
    "@langchain/google-genai": "^0.1.12",
    "aws-sdk": "^2.1692.0",
    "body-parser": "^1.20.3",
    "cheerio": "^1.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "serverless-http": "^3.2.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.147",
    "@types/body-parser": "^1.19.5",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.17.10",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "dotenv-cli": "^7.4.4",
    "eslint": "^8.57.1",
    "serverless": "^3.40.0",
    "serverless-dotenv-plugin": "^6.0.0",
    "serverless-offline": "^13.9.0",
    "serverless-plugin-typescript": "^2.1.5",
    "typescript": "^5.7.2"
  }
}
